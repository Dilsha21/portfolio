# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Admin password ────────────────────────────────────────
# This is the password you'll use to log into /admin
# Change this to something strong before deploying
ADMIN_PASSWORD=change-me-before-deploy

# ── Contact form (optional – uses Resend to forward emails) ──
# Sign up free at https://resend.com and add a key if you want contact form emails
RESEND_API_KEY=
CONTACT_EMAIL=dilshaa.23@cse.mrt.ac.lk
